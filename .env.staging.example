# Line Creek FSC Platform — Staging Environment
# Copy to .env.staging on the staging server and fill in real values.
# NEVER commit .env.staging to git.

# Django Core
DJANGO_SECRET_KEY=generate-with-openssl-rand-base64-50
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=192.168.1.232,ice-skating.lan
DJANGO_SETTINGS_MODULE=config.settings.staging
DJANGO_ENV=staging

# Database
DATABASE_URL=postgresql://linecreek_staging:CHANGE_ME@db:5432/linecreek_staging
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=django-db

# Stripe (use test keys for staging)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Resend for staging transactional email)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_...
DEFAULT_FROM_EMAIL=staging@linecreekfsc.com

# Frontend
NEXT_PUBLIC_API_URL=http://192.168.1.232:8001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STAGING_FRONTEND_URL=http://192.168.1.232:3001
FRONTEND_URL=http://192.168.1.232:3001
CORS_ALLOWED_ORIGINS=http://192.168.1.232:3001

# Skater-Stats API
SKATER_STATS_BASE_URL=https://api.skater-stats.com
SKATER_STATS_CLIENT_VERSION=2.1.28
SKATER_STATS_CACHE_TTL=86400

# Sentry (leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.01
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=

# Web Push (VAPID keys — generate with pywebpush)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@linecreekfsc.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
