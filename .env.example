# Line Creek FSC Platform — Environment Variables
# Copy to .env and fill in real values

# Django Core
DJANGO_SECRET_KEY=change-me-generate-with-openssl-rand-base64-50
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

# Database
DATABASE_URL=postgresql://linecreek:linecreek@db:5432/linecreek
POSTGRES_PASSWORD=linecreek

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=django-db

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Google OAuth (django-allauth)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (console backend for local dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@linecreekfsc.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Skater-Stats API (internal, no key needed)
SKATER_STATS_BASE_URL=https://api.skater-stats.com
SKATER_STATS_CLIENT_VERSION=2.1.28
SKATER_STATS_CACHE_TTL=86400
